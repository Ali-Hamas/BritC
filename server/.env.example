# BritSync Assistant - Backend Environment Variables

# Server Port
PORT=5003

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/britsync

# AI Services
GROQ_API_KEY=your_groq_api_key_here

# LeadHunter Integration (Optional, but recommended)
LEADHUNTER_API_KEY=your_leadhunter_api_key_here

# Google Calendar Integration
# ID of the calendar to book appointments into
GOOGLE_CALENDAR_ID=your_email@gmail.com
# Service account JSON file should be placed in server/service-account.json

# Email Configuration (Nodemailer)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_specific_password_here
GMAIL_RECEIVER=your_notification_receiver_email@gmail.com

# Puppeteer Configuration
PUPPETEER_HEADLESS=true
