# BritSync Assistant - Backend Environment Variables

# Server Port
PORT=5010
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Authentication (Better Auth)
BETTER_AUTH_SECRET=change_me_to_a_long_random_string
BETTER_AUTH_URL=http://localhost:5010

# Supabase (Postgres) - used for auth, team sessions, chat history
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key
# Full Postgres connection string used by Better Auth
DATABASE_URL=postgresql://postgres.your-project:URL_ENCODED_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# AI & External APIs
GROQ_API_KEY=your_groq_api_key_here
LEADHUNTER_API_KEY=your_leadhunter_api_key_here

# Google Calendar Integration
GOOGLE_CALENDAR_ID=your_email@gmail.com
# Place the service account JSON at backend/service-account.json

# Email (Nodemailer / Gmail)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
GMAIL_RECEIVER=your_notification_receiver@gmail.com

# Puppeteer
PUPPETEER_HEADLESS=true
